# Copy to .env and adjust. All values have sane local defaults.

# Base host for worker subdomains: workers are reachable at worker-<id>.<BASE_DOMAIN>
BASE_DOMAIN=localhost

# Port the control plane listens on (serves the app + proxies workers).
PORT=80

# Encryption key for stored secrets (AES-256-GCM). Generate: openssl rand -hex 32
DATA_ENCRYPTION_KEY=

# Where the SQLite DB lives.
DATA_DIR=./data

# Directory holding the user's SSH keys (mounted read-only from the host).
HOST_SSH_DIR=/host-ssh

# Optional headless/CI fallback for pulling private GCP Artifact Registry / GCR
# base images. Normally you set this in the UI instead (Settings → Container
# registry), which stores it encrypted in the DB. If both are set, the UI value
# wins. Service-account key (roles/artifactregistry.reader), raw JSON or base64.
#   base64 (recommended, one line):  base64 -w0 sa-key.json
#   raw JSON also works:             GCP_SA_KEY='{"type":"service_account",...}'
GCP_SA_KEY=
